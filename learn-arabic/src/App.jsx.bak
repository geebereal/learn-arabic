                    padding: "9px 14px", borderRadius: 8, fontSize: 12, fontWeight: 500,
                    border: `1.5px solid ${level === l.label ? GOLD : "#1E1E1E"}`,
                    background: level === l.label ? "#C5A55A0D" : "#111",
                    color: level === l.label ? GOLD : "#888",
                    cursor: "pointer", transition: "all 0.2s", fontFamily: "'DM Sans', sans-serif",
                  }}>{l.tag}</button>
                ))}
              </div>
            </div>
          </Reveal>

          {/* Topics */}
          <Reveal delay={0.38}>
            <div style={{ marginBottom: 28 }}>
              <label style={{ display: "block", fontSize: 12, fontWeight: 600, color: "#666", marginBottom: 8, letterSpacing: ".04em", textTransform: "uppercase" }}>Where do you need Arabic most?</label>
              <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
                {TOPICS.map(t => (
                  <button key={t} onClick={() => setSelectedTopics(p => p.includes(t) ? p.filter(x => x !== t) : [...p, t])}
                    style={{
                      textAlign: "left", padding: "12px 14px", borderRadius: 10,
                      border: `1.5px solid ${selectedTopics.includes(t) ? GOLD : "#1E1E1E"}`,
                      background: selectedTopics.includes(t) ? "#C5A55A0D" : "#111",
                      color: selectedTopics.includes(t) ? "#ddd" : "#888",
                      fontSize: 13, fontWeight: 500, cursor: "pointer", transition: "all 0.2s",
                      fontFamily: "'DM Sans', sans-serif",
                      display: "flex", alignItems: "center", gap: 10,
                    }}
                  >
                    <div style={{
                      width: 18, height: 18, minWidth: 18, borderRadius: 4,
                      border: `1.5px solid ${selectedTopics.includes(t) ? GOLD : "#333"}`,
                      background: selectedTopics.includes(t) ? GOLD : "transparent",
                      display: "flex", alignItems: "center", justifyContent: "center",
                      transition: "all 0.2s",
                    }}>
                      {selectedTopics.includes(t) && <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" strokeWidth="3" strokeLinecap="round"><path d="M20 6L9 17l-5-5"/></svg>}
                    </div>
                    {t}
                  </button>
                ))}
              </div>
            </div>
          </Reveal>

          <Reveal delay={0.4}>
            <button onClick={submit} disabled={submitting} style={{
              width: "100%", padding: "16px", borderRadius: 12, border: "none",
              background: `linear-gradient(135deg, ${GOLD}, #B8963F)`,
              color: "#0A0A0A", fontSize: 15, fontWeight: 700, letterSpacing: ".04em",
              cursor: "pointer", fontFamily: "'DM Sans', sans-serif",
              boxShadow: "0 4px 24px #C5A55A30",
              transition: "all 0.3s ease",
            }}>
              {submitting ? "Submitting..." : "Submit Application"}
            </button>
          </Reveal>

          <Reveal delay={0.45}>
            <p style={{ fontSize: 11, color: "#444", textAlign: "center", marginTop: 16 }}>
              Or message me directly on{" "}
              <a href="https://wa.me/971504273481?text=Hi%20Gabriel%2C%20I'm%20interested%20in%20Business%20Arabic%20lessons" target="_blank" rel="noopener noreferrer" style={{ color: GOLD, textDecoration: "none" }}>WhatsApp</a>
            </p>
          </Reveal>
        </div>
      </section>

      {/* ═══ FOOTER ═══ */}
      <footer style={{ padding: "40px 24px", borderTop: "1px solid #141416", textAlign: "center" }}>
        <p style={{ fontSize: 12, color: "#444" }}>
          <a href="https://geebereal.com" style={{ color: "#666", textDecoration: "none" }}>geebereal.com</a>
          {" · "}
          <a href="https://www.threads.com/@geebereal" target="_blank" rel="noopener noreferrer" style={{ color: GOLD, textDecoration: "none", fontWeight: 600 }}>@geebereal</a>
        </p>
      </footer>
    </div>
  );
}
